{
  "$defs": {
    "ArtifactFingerprint": {
      "description": "Model + environment identity used for artifact-layer comparison.",
      "properties": {
        "model_ref": {
          "title": "Model Ref",
          "type": "string"
        },
        "revision": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Revision"
        },
        "commit_sha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Commit Sha"
        },
        "local_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Local Path"
        },
        "model_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Hash"
        },
        "config_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Config Hash"
        },
        "tokenizer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tokenizer"
        },
        "tokenizer_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tokenizer Hash"
        },
        "chat_template_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Chat Template Hash"
        },
        "model_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Type"
        },
        "architecture": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Architecture"
        },
        "quantization": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Quantization"
        },
        "dtype": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dtype"
        },
        "gguf_metadata": {
          "additionalProperties": true,
          "title": "Gguf Metadata",
          "type": "object"
        },
        "awq_gptq_metadata": {
          "additionalProperties": true,
          "title": "Awq Gptq Metadata",
          "type": "object"
        },
        "lora_adapters": {
          "items": {
            "type": "string"
          },
          "title": "Lora Adapters",
          "type": "array"
        },
        "generation_config": {
          "additionalProperties": true,
          "title": "Generation Config",
          "type": "object"
        },
        "special_tokens": {
          "additionalProperties": true,
          "title": "Special Tokens",
          "type": "object"
        },
        "runtime_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Runtime Version"
        },
        "library_versions": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "Library Versions",
          "type": "object"
        },
        "python_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Python Version"
        },
        "os": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Os"
        },
        "cpu_arch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cpu Arch"
        },
        "gpu": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gpu"
        },
        "driver": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Driver"
        },
        "cuda_or_rocm": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cuda Or Rocm"
        },
        "backend_flags": {
          "additionalProperties": true,
          "title": "Backend Flags",
          "type": "object"
        }
      },
      "required": [
        "model_ref"
      ],
      "title": "ArtifactFingerprint",
      "type": "object"
    },
    "EnvironmentFingerprint": {
      "properties": {
        "python_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Python Version"
        },
        "platform": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Platform"
        },
        "machine": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Machine"
        },
        "processor": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Processor"
        },
        "packages": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "Packages",
          "type": "object"
        },
        "cuda_available": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cuda Available"
        },
        "cuda_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cuda Version"
        },
        "gpu_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gpu Name"
        },
        "torch_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Torch Version"
        },
        "extra": {
          "additionalProperties": true,
          "title": "Extra",
          "type": "object"
        }
      },
      "title": "EnvironmentFingerprint",
      "type": "object"
    },
    "LayerObservation": {
      "properties": {
        "state": {
          "$ref": "#/$defs/LayerState"
        },
        "data": {
          "additionalProperties": true,
          "title": "Data",
          "type": "object"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        },
        "origin": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Origin"
        },
        "origin_kind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Origin Kind"
        }
      },
      "required": [
        "state"
      ],
      "title": "LayerObservation",
      "type": "object"
    },
    "LayerState": {
      "description": "Observation availability of a layer on one backend (not a comparison result).",
      "enum": [
        "OBSERVED",
        "INFERRED",
        "NOT_REQUESTED",
        "NOT_SUPPORTED",
        "NOT_EXPOSED",
        "NOT_OBSERVABLE",
        "UNSUPPORTED",
        "REDACTED",
        "FAILED",
        "ERROR",
        "INCOMPARABLE"
      ],
      "title": "LayerState",
      "type": "string"
    },
    "TraceError": {
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "layer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Layer"
        },
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "TraceError",
      "type": "object"
    }
  },
  "properties": {
    "trace_version": {
      "default": "0",
      "title": "Trace Version",
      "type": "string"
    },
    "trace_id": {
      "title": "Trace Id",
      "type": "string"
    },
    "scenario_name": {
      "title": "Scenario Name",
      "type": "string"
    },
    "backend": {
      "title": "Backend",
      "type": "string"
    },
    "baseline_backend": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Baseline Backend"
    },
    "artifact_fingerprint": {
      "$ref": "#/$defs/ArtifactFingerprint"
    },
    "environment": {
      "anyOf": [
        {
          "$ref": "#/$defs/EnvironmentFingerprint"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "layers": {
      "additionalProperties": {
        "$ref": "#/$defs/LayerObservation"
      },
      "title": "Layers",
      "type": "object"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    },
    "errors": {
      "items": {
        "$ref": "#/$defs/TraceError"
      },
      "title": "Errors",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "duration_ms": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Duration Ms"
    }
  },
  "required": [
    "scenario_name",
    "backend",
    "artifact_fingerprint",
    "layers"
  ],
  "title": "ObservationTrace",
  "type": "object"
}
