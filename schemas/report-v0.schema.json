{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eleanity.dev/schemas/report-v0.schema.json",
  "title": "EleanityCompareReport",
  "type": "object",
  "required": ["schema_version", "run_id", "traces", "diagnosis"],
  "properties": {
    "schema_version": { "type": "string" },
    "run_type": { "type": "string", "enum": ["compare", "ci"] },
    "run_id": { "type": "string" },
    "baseline_backend": { "type": "string" },
    "baseline_model": { "type": "string" },
    "candidate_model": { "type": "string" },
    "scenario": { "type": "object" },
    "environment": { "type": "object" },
    "traces": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    },
    "comparisons": { "type": "object" },
    "diagnosis": {
      "type": "object",
      "required": ["hypothesis", "next_test", "summary"],
      "properties": {
        "first_divergence": { "type": ["string", "null"] },
        "propagation_percent": { "type": "number" },
        "hypothesis": { "type": "string" },
        "next_test": { "type": "string" },
        "summary": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
